<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AssemblyName>JJMasterData.CommandLine</AssemblyName>
        <RootNamespace>JJMasterData.CommandLine</RootNamespace>
        <PackAsTool>true</PackAsTool>
        <ToolCommandName>jjmasterdata</ToolCommandName>
        <PackageId>JJMasterData.CommandLine</PackageId>
        <Description>Command-line and tooling for JJMasterData.</Description>
        <PackageTags>jjmasterdata;dotnet-tool;cli</PackageTags>
    </PropertyGroup>
    <ItemGroup>
        <ProjectReference Include="..\..\MasterData.Core\MasterData.Core.csproj" />
    </ItemGroup>
    <ItemGroup>
      <PackageReference Include="Spectre.Console" />
      <PackageReference Include="Spectre.Console.Cli" />
    </ItemGroup>
</Project>
