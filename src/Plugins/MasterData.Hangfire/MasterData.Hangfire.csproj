<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Description>JJMasterData Hangfire support to background tasks, like exportation and importation.</Description>
		<PackageProjectUrl>https://www.github.com/jjconsulting/jjmasterdata</PackageProjectUrl>
		<PackageTags>hangfire,jjmasterdata</PackageTags>
		<RootNamespace>JJMasterData.Hangfire</RootNamespace>
		<AssemblyName>JJMasterData.Hangfire</AssemblyName>
		<PackageId>JJMasterData.Hangfire</PackageId>
	</PropertyGroup>

	<PropertyGroup>
		<LangVersion>12</LangVersion>
		<Nullable>disable</Nullable>
	</PropertyGroup>
	<ItemGroup>
		<PackageReference Include="Hangfire.Console" />
		<PackageReference Include="Hangfire.Core" />
	</ItemGroup>
	
	<ItemGroup>
		<ProjectReference Include="..\..\MasterData.Commons\MasterData.Commons.csproj" />
		<ProjectReference Include="..\..\MasterData.Core\MasterData.Core.csproj" />
	</ItemGroup>

</Project>
