<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
	  <TargetFrameworks>net4.8;net10.0</TargetFrameworks>
	  <Description>JJMasterData IronPython support for Actions and FormEvents.</Description>
	  <PackageProjectUrl>https://www.github.com/jjconsulting/jjmasterdata</PackageProjectUrl>
	  <RepositoryUrl>https://www.github.com/jjconsulting/jjmasterdata</RepositoryUrl>
	  <PackageTags>python,jjmasterdata,ironpython</PackageTags>
	  <RootNamespace>JJMasterData.Python</RootNamespace>
	  <AssemblyName>JJMasterData.Python</AssemblyName>
  </PropertyGroup>

		<PropertyGroup>
			<LangVersion>12</LangVersion>
		<Nullable>disable</Nullable>
	</PropertyGroup>

		<ItemGroup>
		  <PackageReference Include="IronPython" />
		  <PackageReference Include="IronPython.StdLib" />
	      <PackageReference Include="Microsoft.CSharp" />
		</ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\MasterData.Commons\MasterData.Commons.csproj" />
    <ProjectReference Include="..\..\MasterData.Core\MasterData.Core.csproj" />
  </ItemGroup>


</Project>
